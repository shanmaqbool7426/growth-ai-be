{
  "installCommand": "pnpm install",
  "buildCommand": "node ./build.mjs",
  "functions": {
    "dist/index.mjs": {
      "includeFiles": "dist/**"
    }
  },
  "builds": [
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/index.mjs" }
  ]
}
